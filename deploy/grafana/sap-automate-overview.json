{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus scraping the SAP-Automate /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "SAP-Automate — Overview",
  "tags": ["sap-automate", "mcp", "sap"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Tool latency P95 (gate: 80 ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(mcp_tool_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum(rate(mcp_tool_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.08 } ] }
    },
    {
      "id": 2,
      "title": "Tool error rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mcp_tool_errors_total[5m])) / clamp_min(sum(rate(mcp_tool_calls_total[5m])), 1)",
          "legendFormat": "error ratio"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tool call volume",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(mcp_tool_calls_total[5m]))", "legendFormat": "calls/s" }
      ]
    },
    {
      "id": 4,
      "title": "SAP RFC calls",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(sap_rfc_calls_total[5m]))", "legendFormat": "rfc/s" }
      ]
    },
    {
      "id": 5,
      "title": "Authorization denials (read-only gate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(sap_authz_denied_total[5m]))", "legendFormat": "denied/s" }
      ]
    },
    {
      "id": 6,
      "title": "SAP connection pool in use",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sap_pool_in_use", "legendFormat": "in use" }
      ]
    }
  ]
}
